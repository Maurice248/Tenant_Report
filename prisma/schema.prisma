generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Company {
  id                    String    @id @default(cuid())
  name                  String
  slug                  String    @unique
  logoUrl               String?
  onboardingCompletedAt DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  users         User[]
  invites       CompanyInvite[]
  integration   CompanyIntegration?
  brandConfig   CompanyBrandConfig?
  executions    WorkflowExecution[]

  @@map("companies")
}

model CompanyInvite {
  id          String    @id @default(cuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  email       String
  tokenHash   String    @unique
  role        String    @default("CLIENT")
  invitedById String
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([companyId])
  @@index([email])
  @@map("company_invites")
}

model CompanyIntegration {
  id        String   @id @default(cuid())
  companyId String   @unique
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  metaAccessTokenEnc      String?
  metaAdAccountId         String?
  metaPageId              String?
  elevenLabsApiKeyEnc     String?
  wordpressSiteUrl        String?
  wordpressUsername       String?
  wordpressAppPasswordEnc String?
  n8nApiKeyEnc            String?
  n8nApiBaseUrl           String?
  n8nBlogWorkflowId       String?
  n8nBlogWorkflowName     String?
  n8nWebhooksJson         Json      @default("{}")
  apiTokenSecretsEnc      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("company_integrations")
}

model CompanyBrandConfig {
  id               String   @id @default(cuid())
  companyId        String   @unique
  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  productsServices String   @default("") @map("products_services")
  valueProposition String   @default("") @map("value_proposition")
  brandVoice       String   @default("") @map("brand_voice")
  positioning      String   @default("") @map("positioning")
  competitors      String   @default("") @map("competitors")
  painPoints       String   @default("") @map("pain_points")
  icpMetaAds       String   @default("") @map("icp_meta_ads")
  icpNewsletter    String   @default("") @map("icp_newsletter")
  icpOutreach      String   @default("") @map("icp_outreach")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  snapshots CompanyBrandSnapshot[]

  @@map("company_brand_configs")
}

model CompanyBrandSnapshot {
  id               String             @id @default(cuid())
  brandConfigId    String             @map("brand_config_id")
  brandConfig      CompanyBrandConfig @relation(fields: [brandConfigId], references: [id], onDelete: Cascade)
  productsServices String             @default("") @map("products_services")
  valueProposition String             @default("") @map("value_proposition")
  brandVoice       String             @default("") @map("brand_voice")
  positioning      String             @default("") @map("positioning")
  competitors      String             @default("") @map("competitors")
  painPoints       String             @default("") @map("pain_points")
  icpMetaAds       String             @default("") @map("icp_meta_ads")
  icpNewsletter    String             @default("") @map("icp_newsletter")
  icpOutreach      String             @default("") @map("icp_outreach")
  contentHash      String             @map("content_hash")
  label            String?
  createdAt        DateTime           @default(now()) @map("created_at")

  @@index([brandConfigId])
  @@map("company_brand_snapshots")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  password      String
  role          String    @default("CLIENT")
  companyId     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  company    Company?            @relation(fields: [companyId], references: [id])
  executions WorkflowExecution[]
  sessions   Session[]

  @@index([email])
  @@index([companyId])
  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  sessionToken String   @unique
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model WorkflowExecution {
  id             String    @id @default(cuid())
  userId         String
  companyId      String?
  workflowType   String
  workflowName   String?
  status         String    @default("PENDING")
  n8nExecutionId String?
  inputData      String
  outputData     String?
  errorMessage   String?
  startedAt      DateTime?
  completedAt    DateTime?
  duration       Int?
  createdAt      DateTime  @default(now())

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  company    Company?    @relation(fields: [companyId], references: [id], onDelete: SetNull)
  campaign   Campaign?
  scraperJob ScraperJob?
  cleanupLog CleanupLog?

  @@index([userId])
  @@index([companyId])
  @@index([workflowType])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("workflow_executions")
}

model Campaign {
  id                 String    @id @default(cuid())
  executionId        String    @unique
  campaignName       String
  serviceType        String
  targetRegion       String
  campaignGoal       String    @default("")
  campaignMessage    String    @default("")
  selectedSheet      String
  totalLeadsSent     Int       @default(0)
  successfulSends    Int       @default(0)
  failedSends        Int       @default(0)
  aiGeneratedContent String?
  status             String    @default("PENDING_APPROVAL")
  approvedBy         String?
  approvedAt         DateTime?
  rejectedBy         String?
  rejectedAt         DateTime?
  rejectionReason    String?
  comments           String?
  createdBy          String    @default("")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  execution WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([campaignName])
  @@index([serviceType])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("campaigns")
}

model ScraperJob {
  id            String   @id @default(cuid())
  executionId   String   @unique
  niches        String
  location      String
  maxResults    Int
  totalScraped  Int      @default(0)
  validEmails   Int      @default(0)
  invalidEmails Int      @default(0)
  targetSheet   String
  apifyRunId    String?
  createdAt     DateTime @default(now())

  execution WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([location])
  @@index([createdAt(sort: Desc)])
  @@map("scraper_jobs")
}

model CleanupLog {
  id            String   @id @default(cuid())
  executionId   String   @unique
  totalContacts Int
  deletedCount  Int
  triggerType   String
  cleanupDate   DateTime @default(now())

  execution WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([cleanupDate(sort: Desc)])
  @@map("cleanup_logs")
}
